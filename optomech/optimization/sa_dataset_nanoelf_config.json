{
  "target_transitions": 1000000,
  "check_interval_seconds": 15,
  "max_concurrent_jobs": 1,
  "base_dataset_dir": "./test_datasets",
  "resource_limits": {
    "target_cpu_percent": 95.0,
    "target_memory_percent": 90.0,
    "estimated_cpu_per_job": 8.0,
    "estimated_memory_per_job_gb": 4.0
  },
  "job_command": [
    "poetry",
    "run",
    "python",
    "./optomech/optimization/build_sa_dataset.py",
    "--env-id=optomech-v2",
    "--object_type=single",
    "--ao_interval_ms=100.0",
    "--control_interval_ms=100.0",
    "--frame_interval_ms=100.0",
    "--decision_interval_ms=100.0",
    "--num_atmosphere_layers=0",
    "--aperture_type=nanoelf",
    "--focal_plane_image_size_pixels=128",
    "--observation_mode=image_only",
    "--command_secondaries",
    "--init_differential_motion",
    "--model_wind_diff_motion",
    "--num_envs=1",
    "--reward_function=align",
    "--dataset",
    "--write_frequency=1",
    "--max_episode_steps=100_000",
    "--init_temperature=5.0",
    "--std_dev_patience=100",
    "--sparsity_patience=2000000000000",
    "--temperature_patience=10000000",
    "--init_std_dev=1.0",
    "--scale_patience=10",
    "--scale_stickiness=1.0"
  ]
}