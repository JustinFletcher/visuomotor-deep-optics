{
  "target_transitions": 1000,
  "check_interval_seconds": 15,
  "max_concurrent_jobs": 1,
  "base_dataset_dir": "./test_datasets",
  "resource_limits": {
    "target_cpu_percent": 95.0,
    "target_memory_percent": 90.0,
    "estimated_cpu_per_job": 4.0,
    "estimated_memory_per_job_gb": 2.0
  },
  "job_command": [
    "poetry",
    "run",
    "python",
    "./optomech/optimization/build_sa_dataset.py",
    "--env-id",
    "optomech-v1",
    "--object_type=single",
    "--aperture_type=elf",
    "--observation_mode=image_only",
    "--focal_plane_image_size_pixels=256",
    "--command_secondaries",
    "--command_tip_tilt",
    "--num_envs=1",
    "--reward_function=align",
    "--max_episode_steps=1000",
    "--num_atmosphere_layers=0",
    "--silence=False"
  ]
}
