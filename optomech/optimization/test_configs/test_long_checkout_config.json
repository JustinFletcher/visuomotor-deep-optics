{
  "target_transitions": 10000,
  "check_interval_seconds": 15,
  "max_concurrent_jobs": 1,
  "base_dataset_dir": "./test_datasets",
  "resource_limits": {
    "target_cpu_percent": 95.0,
    "target_memory_percent": 90.0,
    "estimated_cpu_per_job": 8.0,
    "estimated_memory_per_job_gb": 4.0
  },
  "job_command": [
    "poetry",
    "run",
    "python",
    "./optomech/optimization/build_sa_dataset.py",
    "--env-id",
    "optomech-v1",
    "--object_type=single",
    "--ao_interval_ms=5.0",
    "--control_interval_ms=5.0",
    "--frame_interval_ms=5.0",
    "--decision_interval_ms=5.0",
    "--num_atmosphere_layers=0",
    "--aperture_type=elf",
    "--focal_plane_image_size_pixels=512",
    "--observation_mode=image_only",
    "--command_secondaries",
    "--init_differential_motion",
    "--model_wind_diff_motion",
    "--num_envs=1",
    "--reward_function=align",
    "--dataset",
    "--max_episode_steps=10_000",
    "--init_temperature=1.0"
  ]
}
